<script>
  // CURSOR
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove', e => {
    mx=e.clientX; my=e.clientY;
    cursor.style.left=mx-7+'px'; cursor.style.top=my-7+'px';
  });
  setInterval(()=>{
    rx+=(mx-rx)*0.13; ry+=(my-ry)*0.13;
    ring.style.left=rx-19+'px'; ring.style.top=ry-19+'px';
  },16);
 
  // MARQUEE
  const items_en=['Social Media','Graphic Design','Programming & Coding','AI Solutions','Digital Strategy','Brand Identity','Web Development','Content Creation'];
  const items_es=['Redes Sociales','Diseño Gráfico','Programación','Soluciones con IA','Estrategia Digital','Identidad de Marca','Desarrollo Web','Creación de Contenido'];
  function buildMarquee(lang){
    const items=lang==='es'?items_es:items_en;
    const d=[...items,...items,...items];
    document.getElementById('marqueeTrack').innerHTML=d.map(i=>`<div class="marquee-item">${i}<span class="marquee-sep">✦</span></div>`).join('');
  }
 
  // LANG
  function setLang(lang){
    document.querySelectorAll('.lang-btn').forEach(b=>b.classList.toggle('active',b.textContent===lang.toUpperCase()));
    document.querySelectorAll('[data-en]').forEach(el=>{
      const val=el.getAttribute('data-'+lang);
      if(val){ if(el.tagName==='INPUT'||el.tagName==='TEXTAREA') el.placeholder=val; else el.innerHTML=val; }
    });
    document.querySelectorAll('[data-placeholder-'+lang+']').forEach(el=>{ el.placeholder=el.getAttribute('data-placeholder-'+lang); });
    buildMarquee(lang);
    document.documentElement.lang=lang;
  }
  buildMarquee('en');
 
  // REVEAL
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('visible'); });
  },{threshold:0.1});
  document.querySelectorAll('.reveal').forEach((el,i)=>{
    el.style.transitionDelay=(i%4)*0.1+'s';
    obs.observe(el);
  });
</script>
