<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tobor — Digital Marketing</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #FF3EA5;
    --pink-light: #ff6dbf;
    --pink-glow: rgba(255,62,165,0.15);
    --coral: #FF5C5C;
    --black: #111111;
    --white: #FFFFFF;
    --gray: #888888;
    --gray-light: #f4f4f4;
    --gray-mid: #e0e0e0;
    --border: #e8e8e8;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--white);
    color: var(--black);
    font-family: 'Nunito', sans-serif;
    overflow-x: hidden;
    cursor: none;
  }
  .cursor {
    width: 14px; height: 14px;
    background: var(--pink); border-radius: 50%;
    position: fixed; pointer-events: none; z-index: 9999;
  }
  .cursor-ring {
    width: 38px; height: 38px;
    border: 2px solid var(--pink); border-radius: 50%;
    position: fixed; pointer-events: none; z-index: 9998;
    transition: all 0.22s ease; opacity: 0.5;
  }
 
  /* NAV */
  nav {
    position: fixed; top:0; left:0; right:0; z-index:100;
    display:flex; justify-content:space-between; align-items:center;
    padding:1.2rem 4rem;
    background:rgba(255,255,255,0.93);
    backdrop-filter:blur(14px);
    border-bottom:2px solid var(--border);
  }
  .nav-logo { display:flex; align-items:center; text-decoration:none; }
  .nav-links { display:flex; gap:2.5rem; align-items:center; }
  .nav-links a {
    color:var(--gray); text-decoration:none; font-weight:700;
    font-size:0.88rem; letter-spacing:0.06em; text-transform:uppercase;
    transition:color 0.2s;
  }
  .nav-links a:hover { color:var(--pink); }
  .lang-toggle {
    display:flex; gap:0.3rem; background:var(--gray-light);
    border-radius:100px; padding:0.3rem; border:2px solid var(--border);
  }
  .lang-btn {
    background:none; border:none; color:var(--gray);
    font-family:'Space Mono',monospace; font-size:0.78rem; font-weight:700;
    padding:0.3rem 0.9rem; border-radius:100px; cursor:none;
    transition:all 0.2s; letter-spacing:0.05em;
  }
  .lang-btn.active { background:var(--pink); color:var(--white); }
 
  /* HERO */
  .hero {
    min-height:100vh; display:flex; align-items:center;
    padding:8rem 4rem 4rem; position:relative; overflow:hidden;
  }
  .hero-dots {
    position:absolute; inset:0;
    background-image:radial-gradient(circle, var(--gray-mid) 1.5px, transparent 1.5px);
    background-size:32px 32px; opacity:0.55;
    mask-image:radial-gradient(ellipse 80% 90% at 40% 50%, black 30%, transparent 80%);
  }
  .hero-blob {
    position:absolute; width:480px; height:480px;
    background:var(--pink-glow); border-radius:50%; filter:blur(90px);
    top:5%; right:-80px; animation:blobFloat 6s ease-in-out infinite;
  }
  @keyframes blobFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-28px)} }
 
  .hero-content { position:relative; z-index:2; max-width:640px; }
  .hero-badge {
    display:inline-flex; align-items:center; gap:0.6rem;
    background:var(--gray-light); border:2px solid var(--border);
    border-radius:100px; padding:0.5rem 1.2rem;
    font-size:0.78rem; font-weight:700; letter-spacing:0.1em;
    text-transform:uppercase; color:var(--gray); margin-bottom:2rem;
    opacity:0; animation:fadeUp 0.7s ease 0.2s forwards;
  }
  .blink {
    width:8px; height:8px; background:var(--pink); border-radius:50%;
    animation:blinkAnim 1.4s ease infinite;
  }
  @keyframes blinkAnim { 0%,100%{opacity:1} 50%{opacity:0.15} }
 
  .hero h1 {
    font-family:'Nunito',sans-serif;
    font-size:clamp(3.2rem, 7vw, 6.5rem);
    font-weight:900; line-height:1; letter-spacing:-0.03em;
    margin-bottom:1.8rem;
    opacity:0; animation:fadeUp 0.7s ease 0.4s forwards;
  }
  .hero h1 em {
    font-style:normal; color:var(--pink); position:relative; display:inline-block;
  }
  .hero h1 em::after {
    content:''; position:absolute; bottom:4px; left:0; right:0;
    height:6px; background:var(--pink); opacity:0.18; border-radius:3px;
  }
  .hero-desc {
    font-size:1.05rem; line-height:1.78; color:var(--gray);
    margin-bottom:2.5rem; max-width:490px; font-weight:600;
    opacity:0; animation:fadeUp 0.7s ease 0.6s forwards;
  }
  .hero-cta {
    display:flex; gap:1rem; flex-wrap:wrap;
    opacity:0; animation:fadeUp 0.7s ease 0.8s forwards;
  }
  .btn-pink {
    background:var(--pink); color:var(--white); border:none;
    padding:1rem 2.4rem; font-family:'Nunito',sans-serif;
    font-weight:800; font-size:0.95rem; letter-spacing:0.04em;
    border-radius:100px; cursor:none; transition:all 0.22s;
    text-decoration:none; display:inline-flex; align-items:center; gap:0.5rem;
    box-shadow:0 4px 22px rgba(255,62,165,0.3);
  }
  .btn-pink:hover { transform:translateY(-3px); box-shadow:0 10px 36px rgba(255,62,165,0.45); }
  .btn-outline {
    background:transparent; color:var(--black); border:2.5px solid var(--black);
    padding:1rem 2.4rem; font-family:'Nunito',sans-serif;
    font-weight:800; font-size:0.95rem; letter-spacing:0.04em;
    border-radius:100px; cursor:none; transition:all 0.22s; text-decoration:none;
  }
  .btn-outline:hover { background:var(--black); color:var(--white); transform:translateY(-3px); }
 
  .hero-robot {
    position:absolute; right:7%; top:50%; transform:translateY(-50%);
    z-index:2; opacity:0;
    animation:robotIn 1s ease 1s forwards;
  }
  @keyframes robotIn {
    from{opacity:0;transform:translateY(-44%) scale(0.85)}
    to{opacity:1;transform:translateY(-50%) scale(1)}
  }
 
  /* MARQUEE */
  .marquee-wrap {
    overflow:hidden; border-top:2.5px solid var(--black);
    border-bottom:2.5px solid var(--black); padding:1rem 0;
    background:var(--pink);
  }
  .marquee-track {
    display:flex; animation:marquee 24s linear infinite; white-space:nowrap;
  }
  .marquee-item {
    font-family:'Space Mono',monospace; font-size:0.77rem; font-weight:700;
    letter-spacing:0.12em; text-transform:uppercase; color:var(--white);
    display:flex; align-items:center; gap:1.5rem; padding:0 2rem; flex-shrink:0;
  }
  .marquee-sep { color:rgba(255,255,255,0.45); font-size:0.9rem; }
  @keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
 
  /* SERVICES */
  .services { padding:8rem 4rem; background:var(--white); }
  .section-eyebrow {
    font-family:'Space Mono',monospace; font-size:0.74rem; font-weight:700;
    letter-spacing:0.2em; text-transform:uppercase; color:var(--pink);
    margin-bottom:1rem; display:flex; align-items:center; gap:0.8rem;
  }
  .section-eyebrow::before { content:''; width:28px; height:2px; background:var(--pink); }
  .section-title {
    font-family:'Nunito',sans-serif; font-size:clamp(2rem,4vw,3.2rem);
    font-weight:900; letter-spacing:-0.03em; margin-bottom:4rem; line-height:1.1;
  }
  .services-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; }
  .service-card {
    border:2.5px solid var(--border); border-radius:20px; padding:2.8rem;
    position:relative; overflow:hidden; transition:all 0.28s;
    background:var(--white); cursor:none;
  }
  .service-card:hover {
    border-color:var(--pink); transform:translateY(-4px);
    box-shadow:0 14px 44px rgba(255,62,165,0.12);
  }
  .service-card::after {
    content:''; position:absolute; top:-60px; right:-60px;
    width:140px; height:140px; background:var(--pink-glow);
    border-radius:50%; opacity:0; transition:opacity 0.3s;
  }
  .service-card:hover::after { opacity:1; }
  .service-num {
    font-family:'Space Mono',monospace; font-size:0.72rem; font-weight:700;
    color:var(--pink); letter-spacing:0.1em; margin-bottom:1.5rem;
  }
  .service-emoji { font-size:2.8rem; margin-bottom:1.2rem; display:block; }
  .service-name {
    font-family:'Nunito',sans-serif; font-size:1.4rem; font-weight:900;
    margin-bottom:0.8rem; letter-spacing:-0.02em;
  }
  .service-desc { color:var(--gray); font-size:0.95rem; line-height:1.7; font-weight:600; }
  .service-tag {
    display:inline-block; margin-top:1.5rem; background:var(--gray-light);
    border-radius:100px; padding:0.3rem 1rem; font-size:0.75rem; font-weight:700;
    letter-spacing:0.08em; color:var(--gray); text-transform:uppercase;
    transition:all 0.2s;
  }
  .service-card:hover .service-tag { background:var(--pink); color:var(--white); }
 
  /* ABOUT */
  .about {
    padding:8rem 4rem; background:var(--black); color:var(--white);
    position:relative; overflow:hidden;
  }
  .about-inner { display:grid; grid-template-columns:1fr 1fr; gap:6rem; align-items:center; }
  .about .section-eyebrow { color:var(--pink); }
  .about .section-title { color:var(--white); margin-bottom:1.5rem; }
  .about-para { color:var(--gray); font-size:1rem; line-height:1.8; font-weight:600; margin-bottom:2.5rem; }
  .about-stats { display:grid; grid-template-columns:1fr 1fr; gap:1.2rem; }
  .stat {
    background:rgba(255,255,255,0.04); border:1.5px solid rgba(255,255,255,0.08);
    border-radius:16px; padding:1.4rem;
  }
  .stat-number {
    font-family:'Space Mono',monospace; font-size:2rem; font-weight:700;
    color:var(--pink); margin-bottom:0.3rem;
  }
  .stat-label { color:var(--gray); font-size:0.84rem; font-weight:700; }
  .about-visual { display:flex; align-items:center; justify-content:center; }
  .about-card {
    background:rgba(255,255,255,0.04); border:2px solid rgba(255,255,255,0.1);
    border-radius:24px; padding:3rem; text-align:center; max-width:320px;
  }
  .about-card-tag {
    display:inline-block; background:var(--pink); color:white;
    font-family:'Space Mono',monospace; font-size:0.7rem; font-weight:700;
    letter-spacing:0.1em; padding:0.4rem 1rem; border-radius:100px;
    margin-bottom:1.5rem; text-transform:uppercase;
  }
  .about-card p { color:var(--gray); font-size:0.9rem; font-weight:600; margin-top:1.2rem; line-height:1.65; }
 
  /* CONTACT */
  .contact { padding:8rem 4rem; background:var(--white); }
  .contact-inner { max-width:680px; margin:0 auto; text-align:center; }
  .contact .section-title { font-size:clamp(2rem,5vw,3.8rem); margin-bottom:1rem; }
  .contact-sub { color:var(--gray); font-size:1.05rem; line-height:1.75; font-weight:600; margin-bottom:3rem; }
  .contact-form { display:flex; flex-direction:column; gap:1rem; text-align:left; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  .form-input {
    background:var(--gray-light); border:2px solid var(--border); border-radius:12px;
    padding:1rem 1.3rem; color:var(--black); font-family:'Nunito',sans-serif;
    font-size:0.95rem; font-weight:600; outline:none; transition:border-color 0.2s; width:100%;
  }
  .form-input::placeholder { color:#bbb; }
  .form-input:focus { border-color:var(--pink); background:var(--white); }
  textarea.form-input { resize:vertical; min-height:130px; }
 
  /* FOOTER */
  footer {
    padding:2.5rem 4rem; background:var(--black); color:var(--white);
    display:flex; justify-content:space-between; align-items:center;
    border-top:2px solid rgba(255,255,255,0.05);
  }
  .footer-logo {
    font-family:'Space Mono',monospace; font-weight:700;
    font-size:1.1rem; letter-spacing:0.08em;
  }
  .footer-logo span { color:var(--pink); }
  .footer-copy { color:var(--gray); font-size:0.82rem; font-weight:600; }
  .footer-links { display:flex; gap:2rem; }
  .footer-links a { color:var(--gray); text-decoration:none; font-size:0.82rem; font-weight:700; transition:color 0.2s; }
  .footer-links a:hover { color:var(--pink); }
 
  @keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
  .reveal { opacity:0; transform:translateY(22px); transition:opacity 0.65s ease, transform 0.65s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }
 
  @media(max-width:900px) {
    nav { padding:1rem 1.5rem; }
    .nav-links { display:none; }
    .hero { padding:7rem 1.5rem 3rem; }
    .hero-robot { display:none; }
    .services,.about,.contact { padding:5rem 1.5rem; }
    .services-grid { grid-template-columns:1fr; }
    .about-inner { grid-template-columns:1fr; gap:3rem; }
    .about-visual { display:none; }
    .form-row { grid-template-columns:1fr; }
    footer { padding:2rem 1.5rem; flex-direction:column; gap:1rem; text-align:center; }
  }
</style>
</head>
